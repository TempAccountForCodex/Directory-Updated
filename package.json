{
  "name": "techietribe-directory",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "tw-init": "tailwindcss init -p",
    "dev": "vite --open",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "e2e": "node e2e/run-all.mjs",
    "e2e:list": "node e2e/run-all.mjs --filter=list -v",
    "e2e:create": "node e2e/run-all.mjs --filter=create -v",
    "e2e:customize": "node e2e/run-all.mjs --filter=customize -v",
    "e2e:editor": "node e2e/run-all.mjs --filter=editor -v",
    "e2e:preview": "node e2e/run-all.mjs --filter=preview -v",
    "e2e:headed": "node e2e/run-all.mjs --headed -v",
    "e2e:ci": "node e2e/run-all.mjs --ci",
    "e2e:bail": "node e2e/run-all.mjs --bail -v",
    "test:e2e": "node e2e/run-all.mjs --ci"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emailjs/browser": "^4.4.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.13.0",
    "@mui/icons-material": "^5.16.5",
    "@mui/material": "^5.18.0",
    "@mui/styles": "^5.18.0",
    "@mui/x-date-pickers": "^8.7.0",
    "@sentry/react": "^10.47.0",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.5.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.21",
    "ag-grid-community": "^35.0.1",
    "ag-grid-react": "^35.0.1",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.24",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "material-react-table": "^2.13.3",
    "mui-tel-input": "^5.1.2",
    "notistack": "^3.0.2",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-diff-viewer-continued": "^3.4.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-helmet": "^6.1.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^9.16.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.6.0",
    "react-router-dom": "^7.8.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "topojson-client": "^3.1.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/styled": "^11.14.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.21",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.3.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^4.0.15"
  }
}
